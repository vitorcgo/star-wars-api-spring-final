{
	"info": {
		"name": "Star Wars SWAPI - API REST",
		"description": "Coleção completa da API Star Wars com autenticação, rate limiting, idempotência e versionamento.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "apiKey",
			"value": "COLE_SUA_API_KEY_AQUI"
		}
	],
	"item": [
		{
			"name": "Auth - API Keys",
			"item": [
				{
					"name": "Gerar API Key",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"owner\": \"aluno-teste\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/keys",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "keys"]
						}
					}
				},
				{
					"name": "Revogar API Key",
					"request": {
						"method": "DELETE",
						"header": [
							{"key": "X-API-Key", "value": "{{apiKey}}"}
						],
						"url": {
							"raw": "{{baseUrl}}/api/auth/keys/1",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "keys", "1"]
						}
					}
				}
			]
		},
